# === Supabase ===
# Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
# Project Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY="votre-cle-anon"
# Project Settings → API → service_role (SECRET, côté serveur uniquement)
SUPABASE_SERVICE_ROLE_KEY="votre-cle-service-role"

# === Sessions JWT ===
# Chaîne aléatoire longue. Générer avec: openssl rand -base64 32
JWT_SECRET="remplacez-par-un-secret-aleatoire"

# === Chatbot Thierry (DeepSeek) — optionnel ===
# https://platform.deepseek.com/api_keys (nécessite du crédit sur le compte)
DEEPSEEK_API_KEY=""
